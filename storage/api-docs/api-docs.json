{
    "openapi": "3.0.0",
    "info": {
        "title": "Magical Forest Social Network API",
        "description": "Swagger документация API. Шаги: вызовите /api/v1/auth/register или /api/v1/auth/login, скопируйте access_token, нажмите Authorize и вставьте только token (префикс Bearer Swagger добавит автоматически).",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/",
            "description": "Current server"
        }
    ],
    "paths": {
        "/api/v1/auth/register": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Регистрация пользователя",
                "operationId": "authRegister",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Forest User"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "forest@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "password"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "password"
                                    },
                                    "device_name": {
                                        "type": "string",
                                        "example": "swagger-ui"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Создано",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "token_type": {
                                            "type": "string",
                                            "example": "Bearer"
                                        },
                                        "access_token": {
                                            "type": "string",
                                            "example": "1|sanctum-token"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/auth/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Логин пользователя",
                "description": "Возвращает тот же access_token пользователя, пока не вызван /api/v1/auth/logout.",
                "operationId": "authLogin",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "forest@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "password"
                                    },
                                    "device_name": {
                                        "type": "string",
                                        "example": "swagger-ui"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Успех",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "token_type": {
                                            "type": "string",
                                            "example": "Bearer"
                                        },
                                        "access_token": {
                                            "type": "string",
                                            "example": "1|sanctum-token"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Неверные учетные данные"
                    }
                }
            }
        },
        "/api/v1/auth/me": {
            "get": {
                "tags": [
                    "Auth"
                ],
                "summary": "Текущий пользователь",
                "operationId": "authMe",
                "responses": {
                    "200": {
                        "description": "Успех"
                    },
                    "401": {
                        "description": "Не авторизован"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/auth/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Выход и отзыв токена",
                "description": "Удаляет токен пользователя; при следующем логине будет выдан новый.",
                "operationId": "authLogout",
                "responses": {
                    "200": {
                        "description": "Успех"
                    },
                    "401": {
                        "description": "Не авторизован"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/species": {
            "get": {
                "tags": [
                    "Species"
                ],
                "summary": "Список видов",
                "operationId": "speciesIndex",
                "responses": {
                    "200": {
                        "description": "Успех"
                    }
                }
            },
            "post": {
                "tags": [
                    "Species"
                ],
                "summary": "Создать вид",
                "operationId": "speciesStore",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Лиса"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Создано"
                    },
                    "401": {
                        "description": "Не авторизован"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/animals/register": {
            "post": {
                "tags": [
                    "Animals"
                ],
                "summary": "Создать профиль зверя текущего пользователя",
                "operationId": "animalsRegister",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "species_id",
                                    "gender",
                                    "birth_date",
                                    "best_friend_name"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Луна"
                                    },
                                    "nickname": {
                                        "type": "string",
                                        "example": "Лу",
                                        "nullable": true
                                    },
                                    "species_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "gender": {
                                        "type": "string",
                                        "enum": [
                                            "M",
                                            "Ж"
                                        ],
                                        "example": "Ж"
                                    },
                                    "birth_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2020-03-10"
                                    },
                                    "best_friend_name": {
                                        "type": "string",
                                        "example": "Ваня"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Создано"
                    },
                    "422": {
                        "description": "Профиль уже существует/ошибка валидации"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/animals/me": {
            "get": {
                "tags": [
                    "Animals"
                ],
                "summary": "Профиль текущего пользователя",
                "operationId": "animalsMe",
                "responses": {
                    "200": {
                        "description": "Успех"
                    },
                    "404": {
                        "description": "Профиль не найден"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/animals/me/friends": {
            "get": {
                "tags": [
                    "Friendships"
                ],
                "summary": "Список друзей текущего пользователя",
                "operationId": "friendsIndex",
                "responses": {
                    "200": {
                        "description": "Успех"
                    },
                    "422": {
                        "description": "Сначала создайте профиль зверя"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/friendships": {
            "post": {
                "tags": [
                    "Friendships"
                ],
                "summary": "Добавить друга текущему зверю",
                "operationId": "friendshipsStore",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "friend_id"
                                ],
                                "properties": {
                                    "friend_id": {
                                        "type": "integer",
                                        "example": 2
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Создано"
                    },
                    "422": {
                        "description": "Ошибка валидации/логики"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/animals/me/recommendations": {
            "get": {
                "tags": [
                    "Recommendations"
                ],
                "summary": "Рекомендации друзей текущего пользователя",
                "operationId": "recommendationsIndex",
                "responses": {
                    "200": {
                        "description": "Успех"
                    },
                    "422": {
                        "description": "Сначала создайте профиль зверя"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/chats": {
            "post": {
                "tags": [
                    "Chats"
                ],
                "summary": "Создать чат",
                "operationId": "chatsStore",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "participant_ids"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Лесной чат",
                                        "nullable": true
                                    },
                                    "participant_ids": {
                                        "type": "array",
                                        "items": {
                                            "type": "integer",
                                            "example": 2
                                        }
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Создано"
                    },
                    "422": {
                        "description": "Ошибка валидации/логики"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/chats/{chat}/messages": {
            "get": {
                "tags": [
                    "Chats"
                ],
                "summary": "Сообщения чата",
                "operationId": "chatMessagesIndex",
                "parameters": [
                    {
                        "name": "chat",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Успех"
                    },
                    "403": {
                        "description": "Нет доступа"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Chats"
                ],
                "summary": "Отправить сообщение в чат",
                "operationId": "chatMessagesStore",
                "parameters": [
                    {
                        "name": "chat",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "body"
                                ],
                                "properties": {
                                    "body": {
                                        "type": "string",
                                        "maxLength": 128,
                                        "example": "Привет!"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Создано"
                    },
                    "422": {
                        "description": "Ошибка валидации/логики"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "description": "Нажмите Authorize и вставьте только token из /api/v1/auth/register или /api/v1/auth/login (Bearer добавится автоматически).",
                "bearerFormat": "Token",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Регистрация и токены"
        },
        {
            "name": "Species",
            "description": "Каталог видов"
        },
        {
            "name": "Animals",
            "description": "Профиль зверя пользователя"
        },
        {
            "name": "Friendships",
            "description": "Дружба"
        },
        {
            "name": "Recommendations",
            "description": "Рекомендации"
        },
        {
            "name": "Chats",
            "description": "Чаты и сообщения"
        }
    ]
}